#~ msgid ""
#~ "<br/>Crafting spaces where creativity meets functionality,<br/>one design "
#~ "at a time.<br/><br/>"
#~ msgstr ""
#~ "<br/>Räume schaffen, in denen Kreativität auf Funktionalität trifft,<br/"
