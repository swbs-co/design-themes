msgid "2,000 parents<br/> brought their kid to our nursery."
msgstr "2 000 vanhempaa<br/> on tuonut lapsensa päiväkotiimme."

#. module: theme_kiddo
#: model_terms:theme.ir.ui.view,arch:theme_kiddo.s_three_columns
msgid ""
"<br/>\n"
"        For every kid"
msgstr ""
"<br/>\n"
"        Jokaiselle lapselle"

#. module: theme_kiddo
#: model_terms:theme.ir.ui.view,arch:theme_kiddo.s_three_columns
