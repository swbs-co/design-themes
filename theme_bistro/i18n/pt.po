msgstr "O lugar é perfeito para grupos ou para um encontro casual."

#. module: theme_bistro
#: model_terms:theme.ir.ui.view,arch:theme_bistro.s_image_title
msgid ""
"Transform your dining experience with our new menu, where classic dishes "
"meet modern creativity. Elevate your palate with flavors that blend "
"tradition and innovation seamlessly."
msgstr ""
"Transforme sua experiência gastronômica com nosso novo cardápio, onde os "
"pratos clássicos encontram a criatividade moderna. Eleve seu paladar com "
"sabores que misturam tradição e inovação com perfeição."

#~ msgid ""
#~ "\" A perfect spot for great food. <br/>Cozy atmosphere, excellent "
#~ "service, and delicious meals. \""
#~ msgstr ""
#~ "\"Um local perfeito para uma ótima comida. <br/>Ambiente aconchegante, "
#~ "serviço excelente e refeições deliciosas.\""

#~ msgid ""
