#~ "で、ゲストが簡単にメニューを探して楽しむことができます。<br/>"

#~ msgid ""
#~ "<br/>Where every meal is a celebration of flavor and ambiance.<br/><br/>"
#~ msgstr "<br/>お食事のひとときが、味わいと雰囲気の祝祭となる場所。<br/><br/>"

